{
  "version": 2,
  "builds": [
    {
      "src": "api/send-whatsapp.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/send-whatsapp",
      "dest": "/api/send-whatsapp.js"
    }
  ],
  "env": {
    "WIREWEB_API_KEY": "@wireweb-api-key",
    "WIREWEB_BASE_URL": "@wireweb-base-url"
  }
}
