{
  "version": 2,
  "builds": [
    {
      "src": "api/send-whatsapp.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/verify-otp.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/send-whatsapp",
      "dest": "/api/send-whatsapp.js"
    },
    {
      "src": "/api/verify-otp",
      "dest": "/api/verify-otp.js"
    }
  ],
  "env": {
    "WIREWEB_API_KEY": "@wireweb_api_key",
    "WIREWEB_BASE_URL": "@wireweb_base_url"
  }
}
