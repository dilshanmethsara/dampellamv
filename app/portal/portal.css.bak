.portal-theme {
  --background: oklch(0.98 0.005 285);
  --foreground: oklch(0.15 0.005 285);
  --card: oklch(1 0 0);
  --card-foreground: oklch(0.15 0.005 285);
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.15 0.005 285);
  --primary: oklch(0.15 0.005 285);
  --primary-foreground: oklch(0.98 0 0);
  --secondary: oklch(0.94 0.005 285);
  --secondary-foreground: oklch(0.15 0.005 285);
  --muted: oklch(0.94 0.005 285);
  --muted-foreground: oklch(0.45 0.005 285);
  --accent: oklch(0.94 0.005 285);
  --accent-foreground: oklch(0.15 0.005 285);
  --destructive: oklch(0.577 0.245 27.325);
  --destructive-foreground: oklch(0.98 0 0);
  --border: oklch(0.88 0.005 285);
  --input: oklch(0.94 0.005 285);
  --ring: oklch(0.45 0.005 285);
  --chart-1: oklch(0.646 0.222 41.116);
  --chart-2: oklch(0.6 0.118 184.704);
  --chart-3: oklch(0.398 0.07 227.392);
  --chart-4: oklch(0.828 0.189 84.429);
  --chart-5: oklch(0.769 0.188 70.08);
  --radius: 0.5rem;
}

.dark .portal-theme,
.portal-theme.dark {
  --background: oklch(0.13 0.005 285);
  --foreground: oklch(0.98 0 0);
  --card: oklch(0.16 0.005 285);
  --card-foreground: oklch(0.98 0 0);
  --popover: oklch(0.16 0.005 285);
  --popover-foreground: oklch(0.98 0 0);
  --primary: oklch(0.98 0 0);
  --primary-foreground: oklch(0.13 0.005 285);
  --secondary: oklch(0.22 0.005 285);
  --secondary-foreground: oklch(0.98 0 0);
  --muted: oklch(0.22 0.005 285);
  --muted-foreground: oklch(0.65 0 0);
  --accent: oklch(0.22 0.005 285);
  --accent-foreground: oklch(0.98 0 0);
  --destructive: oklch(0.577 0.245 27.325);
  --destructive-foreground: oklch(0.98 0 0);
  --border: oklch(0.28 0.005 285);
  --input: oklch(0.22 0.005 285);
  --ring: oklch(0.65 0 0);
}
